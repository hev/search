#!/usr/bin/env bash
# Run cargo inside the pinned Rust container.
#
# Bind-mounts the project at /work and stores cargo's registry/git cache
# and the build target under project-local directories so nothing leaks
# outside the repo and no host toolchain is required.

set -Eeuo pipefail

IMAGE="firnflow-rust-dev:1.94"
PROJECT_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

if ! docker image inspect "${IMAGE}" >/dev/null 2>&1; then
    echo "Building ${IMAGE} (first run only)..." >&2
    docker build -t "${IMAGE}" -f "${PROJECT_ROOT}/Dockerfile.dev" "${PROJECT_ROOT}" >&2
fi

mkdir -p "${PROJECT_ROOT}/.cargo-cache"

# Mount the host's ~/.aws read-only when AWS_PROFILE is set so that
# the AWS-backed conditional-write tests can reach real AWS S3 via
# the host's configured credentials. Path redirected to /aws so we
# don't conflict with the container's HOME layout.
AWS_MOUNT_ARGS=()
if [ -n "${AWS_PROFILE:-}" ] && [ -d "${HOME}/.aws" ]; then
    AWS_MOUNT_ARGS+=(
        -v "${HOME}/.aws:/aws:ro"
        -e "AWS_SHARED_CREDENTIALS_FILE=/aws/credentials"
        -e "AWS_CONFIG_FILE=/aws/config"
        -e "AWS_PROFILE=${AWS_PROFILE}"
        -e "AWS_REGION=${AWS_REGION:-eu-west-1}"
    )
fi

# Mount the GCS service-account JSON read-only when
# GOOGLE_APPLICATION_CREDENTIALS (or GOOGLE_SERVICE_ACCOUNT_PATH) points
# at an existing file on the host. Path redirected to /gcs/key.json
# inside the container.
GCS_MOUNT_ARGS=()
GCS_KEY_HOST_PATH=""
if [ -n "${GOOGLE_APPLICATION_CREDENTIALS:-}" ] && [ -f "${GOOGLE_APPLICATION_CREDENTIALS}" ]; then
    GCS_KEY_HOST_PATH="${GOOGLE_APPLICATION_CREDENTIALS}"
elif [ -n "${GOOGLE_SERVICE_ACCOUNT_PATH:-}" ] && [ -f "${GOOGLE_SERVICE_ACCOUNT_PATH}" ]; then
    GCS_KEY_HOST_PATH="${GOOGLE_SERVICE_ACCOUNT_PATH}"
fi
if [ -n "${GCS_KEY_HOST_PATH}" ]; then
    GCS_MOUNT_ARGS+=(
        -v "${GCS_KEY_HOST_PATH}:/gcs/key.json:ro"
        -e "GOOGLE_APPLICATION_CREDENTIALS=/gcs/key.json"
    )
fi

# Default FIRNFLOW_S3_BUCKET to the local-dev MinIO bucket when the
# host hasn't picked a backend at all — but only then. Forwarding the
# default unconditionally would collide with a host that has set
# FIRNFLOW_STORAGE_URI=gs://... or FIRNFLOW_STORAGE_URI=s3://other,
# tripping the resolver's strict-disagreement check at startup.
BUCKET_DEFAULT_ARGS=()
if [ -z "${FIRNFLOW_STORAGE_URI:-}" ]; then
    BUCKET_DEFAULT_ARGS+=(
        -e "FIRNFLOW_S3_BUCKET=${FIRNFLOW_S3_BUCKET:-firnflow-test}"
    )
fi

exec docker run --rm --init \
    --network host \
    --user "$(id -u):$(id -g)" \
    -v "${PROJECT_ROOT}:/work" \
    -e CARGO_HOME=/work/.cargo-cache \
    -e CARGO_TARGET_DIR=/work/target \
    -e CARGO_TERM_COLOR=always \
    ${FIRNFLOW_STORAGE_URI:+-e FIRNFLOW_STORAGE_URI="$FIRNFLOW_STORAGE_URI"} \
    ${FIRNFLOW_S3_ENDPOINT:+-e FIRNFLOW_S3_ENDPOINT="$FIRNFLOW_S3_ENDPOINT"} \
    ${FIRNFLOW_S3_ACCESS_KEY:+-e FIRNFLOW_S3_ACCESS_KEY="$FIRNFLOW_S3_ACCESS_KEY"} \
    ${FIRNFLOW_S3_SECRET_KEY:+-e FIRNFLOW_S3_SECRET_KEY="$FIRNFLOW_S3_SECRET_KEY"} \
    "${BUCKET_DEFAULT_ARGS[@]}" \
    -e FIRNFLOW_AWS_BUCKET="${FIRNFLOW_AWS_BUCKET:-firnflow-cloudfloe}" \
    ${FIRNFLOW_BENCH_DIM:+-e FIRNFLOW_BENCH_DIM="$FIRNFLOW_BENCH_DIM"} \
    ${FIRNFLOW_BENCH_ROWS:+-e FIRNFLOW_BENCH_ROWS="$FIRNFLOW_BENCH_ROWS"} \
    ${FIRNFLOW_BENCH_QUERIES:+-e FIRNFLOW_BENCH_QUERIES="$FIRNFLOW_BENCH_QUERIES"} \
    ${FIRNFLOW_BENCH_OUT:+-e FIRNFLOW_BENCH_OUT="$FIRNFLOW_BENCH_OUT"} \
    ${FIRNFLOW_BENCH_CACHE_RAM_MB:+-e FIRNFLOW_BENCH_CACHE_RAM_MB="$FIRNFLOW_BENCH_CACHE_RAM_MB"} \
    ${FIRNFLOW_BENCH_CACHE_NVME_MB:+-e FIRNFLOW_BENCH_CACHE_NVME_MB="$FIRNFLOW_BENCH_CACHE_NVME_MB"} \
    ${FIRNFLOW_BENCH_INDEX_NPROBES:+-e FIRNFLOW_BENCH_INDEX_NPROBES="$FIRNFLOW_BENCH_INDEX_NPROBES"} \
    ${FIRNFLOW_SEM_REPS:+-e FIRNFLOW_SEM_REPS="$FIRNFLOW_SEM_REPS"} \
    ${FIRNFLOW_SEM_K:+-e FIRNFLOW_SEM_K="$FIRNFLOW_SEM_K"} \
    ${FIRNFLOW_SEM_THRESHOLD:+-e FIRNFLOW_SEM_THRESHOLD="$FIRNFLOW_SEM_THRESHOLD"} \
    ${FIRNFLOW_SEM_COSINE_SWEEP:+-e FIRNFLOW_SEM_COSINE_SWEEP="$FIRNFLOW_SEM_COSINE_SWEEP"} \
    ${FIRNFLOW_SEM_FILL:+-e FIRNFLOW_SEM_FILL="$FIRNFLOW_SEM_FILL"} \
    ${FIRNFLOW_SEM_OUT:+-e FIRNFLOW_SEM_OUT="$FIRNFLOW_SEM_OUT"} \
    ${FIRNFLOW_S3_REGION:+-e FIRNFLOW_S3_REGION="$FIRNFLOW_S3_REGION"} \
    ${R2_ENDPOINT:+-e R2_ENDPOINT="$R2_ENDPOINT"} \
    ${R2_ACCESS_KEY:+-e R2_ACCESS_KEY="$R2_ACCESS_KEY"} \
    ${R2_SECRET_KEY:+-e R2_SECRET_KEY="$R2_SECRET_KEY"} \
    ${R2_BUCKET:+-e R2_BUCKET="$R2_BUCKET"} \
    ${TIGRIS_ENDPOINT:+-e TIGRIS_ENDPOINT="$TIGRIS_ENDPOINT"} \
    ${TIGRIS_ACCESS_KEY:+-e TIGRIS_ACCESS_KEY="$TIGRIS_ACCESS_KEY"} \
    ${TIGRIS_SECRET_KEY:+-e TIGRIS_SECRET_KEY="$TIGRIS_SECRET_KEY"} \
    ${TIGRIS_BUCKET:+-e TIGRIS_BUCKET="$TIGRIS_BUCKET"} \
    ${B2_ENDPOINT:+-e B2_ENDPOINT="$B2_ENDPOINT"} \
    ${B2_ACCESS_KEY:+-e B2_ACCESS_KEY="$B2_ACCESS_KEY"} \
    ${B2_SECRET_KEY:+-e B2_SECRET_KEY="$B2_SECRET_KEY"} \
    ${B2_BUCKET:+-e B2_BUCKET="$B2_BUCKET"} \
    ${B2_REGION:+-e B2_REGION="$B2_REGION"} \
    ${GCS_ENDPOINT:+-e GCS_ENDPOINT="$GCS_ENDPOINT"} \
    ${GCS_ACCESS_KEY:+-e GCS_ACCESS_KEY="$GCS_ACCESS_KEY"} \
    ${GCS_SECRET_KEY:+-e GCS_SECRET_KEY="$GCS_SECRET_KEY"} \
    ${GCS_BUCKET:+-e GCS_BUCKET="$GCS_BUCKET"} \
    ${GCS_REGION:+-e GCS_REGION="$GCS_REGION"} \
    ${SPACES_ENDPOINT:+-e SPACES_ENDPOINT="$SPACES_ENDPOINT"} \
    ${SPACES_ACCESS_KEY:+-e SPACES_ACCESS_KEY="$SPACES_ACCESS_KEY"} \
    ${SPACES_SECRET_KEY:+-e SPACES_SECRET_KEY="$SPACES_SECRET_KEY"} \
    ${SPACES_BUCKET:+-e SPACES_BUCKET="$SPACES_BUCKET"} \
    ${SPACES_REGION:+-e SPACES_REGION="$SPACES_REGION"} \
    ${GOOGLE_SERVICE_ACCOUNT_KEY:+-e GOOGLE_SERVICE_ACCOUNT_KEY="$GOOGLE_SERVICE_ACCOUNT_KEY"} \
    "${AWS_MOUNT_ARGS[@]}" \
    "${GCS_MOUNT_ARGS[@]}" \
    -w /work \
    "${IMAGE}" \
    cargo "$@"
